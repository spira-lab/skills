# Base URL for the Spira app or API host.
SPIRA_BASE_URL=https://your-spira-host.example.com

# Authentication mode for HTTP requests: cookie or bearer.
SPIRA_AUTH_MODE=cookie

# Raw Cookie header value when using cookie auth.
# Example: session=abc123; other=value
SPIRA_COOKIE_HEADER=

# Bearer token when using bearer auth.
SPIRA_BEARER_TOKEN=

# Default timeout in seconds for HTTP requests.
SPIRA_TIMEOUT_SECONDS=30

# Optional defaults that some skills may use as convenience context.
SPIRA_DEFAULT_PERSONA_ID=
SPIRA_DEFAULT_PLATFORM=
SPIRA_DEFAULT_WORKSPACE_ID=
SPIRA_DEFAULT_TIMEZONE=
